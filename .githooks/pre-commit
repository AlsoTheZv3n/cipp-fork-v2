#!/bin/bash
# Pre-commit hook: prevent secrets from being committed
# Install: git config core.hooksPath .githooks

RED='\033[0;31m'
NC='\033[0m'

# Patterns that should NEVER be in committed code
PATTERNS=(
    'AZURE_CLIENT_SECRET=.*[A-Za-z0-9~_.]{20}'
    'AUTH_CLIENT_SECRET=.*[A-Za-z0-9~_.]{20}'
    'sk-proj-[A-Za-z0-9_-]{20}'
    'TempP@ss'
    'password.*=.*[A-Za-z0-9!@#$%]{12}'
)

# Only check staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND=0
for pattern in "${PATTERNS[@]}"; do
    MATCHES=$(echo "$STAGED_FILES" | xargs grep -lE "$pattern" 2>/dev/null | grep -v "\.example\|\.production\|\.gitignore\|pre-commit\|\.md$")
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}SECRET DETECTED in:${NC}"
        echo "$MATCHES" | while read f; do
            echo "  $f"
            grep -nE "$pattern" "$f" 2>/dev/null | head -3 | while read line; do
                echo "    $line"
            done
        done
        FOUND=1
    fi
done

# Check for .env files being committed
ENV_FILES=$(echo "$STAGED_FILES" | grep -E "^\.env$|/\.env$|\.env\.local$" | grep -v "example\|production")
if [ -n "$ENV_FILES" ]; then
    echo -e "${RED}WARNING: .env file being committed:${NC}"
    echo "$ENV_FILES"
    FOUND=1
fi

if [ "$FOUND" = "1" ]; then
    echo ""
    echo -e "${RED}COMMIT BLOCKED: Secrets detected. Remove them before committing.${NC}"
    echo "Use 'git reset HEAD <file>' to unstage, or add to .gitignore."
    exit 1
fi

exit 0
