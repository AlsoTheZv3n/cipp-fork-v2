# Database
DATABASE_URL=postgresql+asyncpg://cipp:cipp_dev@localhost:5433/cipp

# Azure AD / GDAP (for Graph API calls to customer tenants)
AZURE_TENANT_ID=your-partner-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Azure AD / Auth (for CIPP dashboard login — leave empty for dev-mode auto-login)
AUTH_TENANT_ID=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:8055/.auth/callback
JWT_SECRET=change-me-in-production
SESSION_EXPIRY_HOURS=24

# PowerShell Runner
PS_RUNNER_URL=http://localhost:8001

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_URL=http://localhost:3000
